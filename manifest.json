{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "version": "0.5.0",
  "default_locale": "en",

  "permissions": [
    "tabs",
    "storage"
  ],

"background": {
  "service_worker": "js/tbm_background.js"
},

"content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["js/tbm_sts_sites.js", "js/tbm_content.js"],
    "run_at": "document_idle"
  }
],

  "action": {
    "default_title": "__MSG_extName__"
  },

  "options_page": "options.html",

  "icons": {
    "16": "tbm_icon-16.png",
    "32": "tbm_icon-32.png",
    "48": "tbm_icon-48.png",
    "128": "tbm_icon-128.png"
  },


  "commands": {
    "tbm_switch_to_previous_tab": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "__MSG_cmdSwitchPreviousTab__"
    }
  }
}